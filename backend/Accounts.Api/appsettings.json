{
  "Deployment": {
    "Mode": "Development",
    "InstallationId": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ImportLimits": {
    "MaxCsvBytes": 5242880,
    "MaxRows": 25000,
    "AllowedExtensions": [ ".csv", ".txt" ],
    "AllowedContentTypes": [
      "text/csv",
      "application/csv",
      "text/plain",
      "application/vnd.ms-excel",
      "application/octet-stream"
    ]
  },
  "Idempotency": {
    "RetentionDays": 30,
    "CleanupIntervalMinutes": 360,
    "CleanupBatchSize": 1000,
    "MaxResponseBytes": 16777216
  },
  "PrivacyGovernance": {
    "LoginSecurityEventRetentionDays": 30,
    "TerminalIdentityArtifactRetentionHours": 24,
    "UsedRecoveryCodeRetentionDays": 30,
    "SubjectRequestMetadataRetentionYears": 3,
    "StatutoryRecordMinimumYears": 6,
    "RetentionWorkerIntervalHours": 24
  },
  "DatabaseTenantIsolation": {
    "Required": false,
    "ApplicationGroupRole": "accounts_api_rls",
    "ApplicationLoginRole": "accounts_api"
  },
  "IdentitySecurity": {
    "RequireInProduction": true,
    "BreachedPasswordCheckEnabled": true,
    "BreachedPasswordFailClosed": true,
    "PwnedPasswordsRangeBaseUrl": "https://api.pwnedpasswords.com/range/",
    "PwnedPasswordsTimeoutSeconds": 5,
    "PwnedPasswordsMaximumResponseBytes": 2000000,
    "ActiveMfaEncryptionKeyId": "",
    "MfaEncryptionKeys": []
  },
  "DeadlineDelivery": {
    "RequireInProduction": true,
    "Enabled": false,
    "Provider": "Webhook",
    "DueSoonDays": 30,
    "SchedulerIntervalMinutes": 15,
    "BatchSize": 50,
    "RetryBaseMinutes": 5,
    "RetryMaximumMinutes": 1440,
    "DeliveryLeaseMinutes": 10,
    "MaximumAutomaticAttempts": 10,
    "OperatorAlertAfterAttempts": 1
  },
  "PlatformMetrics": {
    "RequireInProduction": true,
    "Enabled": true,
    "RestrictedSnapshotEnabled": true,
    "WindowMinutes": 15,
    "RequestLatencyP95Milliseconds": 1000,
    "RequestErrorRatePercent": 2,
    "JobFailureThreshold": 1,
    "DatabaseActiveConnectionThreshold": 80,
    "DocumentGenerationP95Milliseconds": 10000,
    "BackupMaximumAgeHours": 26,
    "ReminderFailureBacklogThreshold": 1,
    "ReminderPendingBacklogThreshold": 100,
    "AlertEvaluationIntervalMinutes": 5,
    "AlertRepeatMinutes": 30,
    "MaximumObservationsPerSeries": 100000
  },
  "RateLimits": {
    "PermitLimitPerMinute": 300
  },
  "SizeThresholds": {
    "EffectiveFrom": "2024-01-01",
    "EarlyElectionEffectiveFrom": "2023-01-01",
    "Micro": {
      "Turnover": 900000,
      "BalanceSheet": 450000,
      "Employees": 10
    },
    "Small": {
      "Turnover": 15000000,
      "BalanceSheet": 7500000,
      "Employees": 50
    },
    "Medium": {
      "Turnover": 50000000,
      "BalanceSheet": 25000000,
      "Employees": 250
    },
    "HistoricalMicro": {
      "Turnover": 700000,
      "BalanceSheet": 350000,
      "Employees": 10
    },
    "HistoricalSmall": {
      "Turnover": 12000000,
      "BalanceSheet": 6000000,
      "Employees": 50
    },
    "HistoricalMedium": {
      "Turnover": 40000000,
      "BalanceSheet": 20000000,
      "Employees": 250
    }
  }
}
