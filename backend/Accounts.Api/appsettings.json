{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=accounts;Username=accounts;Password=accounts_dev"
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5173",
    "http://localhost:5174"
  ],
  "ImportLimits": {
    "MaxCsvBytes": 5242880,
    "MaxRows": 25000,
    "AllowedExtensions": [ ".csv", ".txt" ],
    "AllowedContentTypes": [
      "text/csv",
      "application/csv",
      "text/plain",
      "application/vnd.ms-excel",
      "application/octet-stream"
    ]
  },
  "RateLimits": {
    "PermitLimitPerMinute": 300
  },
  "DatabaseStartup": {
    "AutoMigrateOnStartup": true,
    "SeedDemoData": true,
    "AllowStartupMigrationInProduction": false,
    "AllowDemoSeedInProduction": false,
    "AllowDevelopmentDatabasePasswordInProduction": false
  },
  "SizeThresholds": {
    "EffectiveFrom": "2024-01-01",
    "Micro": {
      "Turnover": 900000,
      "BalanceSheet": 450000,
      "Employees": 10
    },
    "Small": {
      "Turnover": 15000000,
      "BalanceSheet": 7500000,
      "Employees": 50
    },
    "Medium": {
      "Turnover": 50000000,
      "BalanceSheet": 25000000,
      "Employees": 250
    }
  }
}
