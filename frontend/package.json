{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "overrides": {
    "next": {
      "postcss": "8.5.14"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:clean": "node scripts/verify-clean-build.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "test:readiness": "node --experimental-strip-types scripts/verify-readiness.mjs",
    "test:proxy": "node --experimental-strip-types scripts/verify-api-proxy.mjs",
    "test:auth": "node --experimental-strip-types scripts/verify-auth-session.mjs",
    "test:api-client": "node --experimental-strip-types scripts/verify-api-client.mjs",
    "test:unit": "node --test --experimental-strip-types \"tests/*.test.mjs\"",
    "test:render": "vitest run",
    "test": "npm run test:unit && npm run test:render && npm run test:readiness && npm run test:proxy && npm run test:auth && npm run test:api-client"
  },
  "dependencies": {
    "@heroui/react": "3.0.1",
    "@heroui/theme": "2.4.26",
    "framer-motion": "12.38.0",
    "lucide-react": "1.7.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "2.0.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "20.19.37",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "27.4.0",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  }
}
