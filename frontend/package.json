{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "next": {
      "postcss": "8.5.14"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:clean": "node scripts/verify-clean-build.mjs",
    "start": "node scripts/start-standalone.mjs",
    "lint": "eslint",
    "test:readiness": "node --experimental-strip-types scripts/verify-readiness.mjs",
    "test:proxy": "node --experimental-strip-types scripts/verify-api-proxy.mjs",
    "test:auth": "node --experimental-strip-types scripts/verify-auth-session.mjs",
    "test:api-client": "node --experimental-strip-types scripts/verify-api-client.mjs",
    "test:visual": "node scripts/visual-smoke.mjs",
    "test:visual:verify": "node scripts/verify-visual-smoke-artifacts.mjs",
    "test:unit": "node --test --experimental-strip-types \"tests/*.test.mjs\"",
    "test:render": "vitest run --pool=forks --maxWorkers=1 --minWorkers=1",
    "test": "npm run test:unit && npm run test:render && npm run test:readiness && npm run test:proxy && npm run test:auth && npm run test:api-client"
  },
  "dependencies": {
    "@heroui/react": "3.2.1",
    "@heroui/styles": "3.2.1",
    "framer-motion": "12.42.2",
    "lucide-react": "1.23.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "jsdom": "27.4.0",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  }
}
