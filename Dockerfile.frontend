FROM node:24-alpine@sha256:a0b9bf06e4e6193cf7a0f58816cc935ff8c2a908f81e6f1a95432d679c54fbfd AS deps
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

FROM node:24-alpine@sha256:a0b9bf06e4e6193cf7a0f58816cc935ff8c2a908f81e6f1a95432d679c54fbfd AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY frontend/ .
ARG API_URL
ARG NEXT_PUBLIC_DEMO_LOGIN_EMAIL
ENV API_URL=$API_URL
ENV NEXT_PUBLIC_DEMO_LOGIN_EMAIL=$NEXT_PUBLIC_DEMO_LOGIN_EMAIL
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

FROM node:24-alpine@sha256:a0b9bf06e4e6193cf7a0f58816cc935ff8c2a908f81e6f1a95432d679c54fbfd AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
USER nextjs
EXPOSE 3000
ENV PORT=3000
# Next.js standalone binds to $HOSTNAME; Docker defaults it to the container id,
# which leaves the server unreachable on localhost (breaking the healthcheck).
# Bind to all interfaces so the in-container healthcheck and port publish both work.
ENV HOSTNAME=0.0.0.0
CMD ["node", "server.js"]
