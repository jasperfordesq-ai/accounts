FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66 AS deps
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66 AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY frontend/ .
ARG API_URL
ARG NEXT_PUBLIC_DEMO_LOGIN_EMAIL
ARG NEXT_PUBLIC_DEMO_TENANT_SLUG
ENV API_URL=$API_URL
ENV NEXT_PUBLIC_DEMO_LOGIN_EMAIL=$NEXT_PUBLIC_DEMO_LOGIN_EMAIL
ENV NEXT_PUBLIC_DEMO_TENANT_SLUG=$NEXT_PUBLIC_DEMO_TENANT_SLUG
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66 AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN rm -rf \
    /usr/local/lib/node_modules/npm \
    /usr/local/lib/node_modules/corepack \
    /usr/local/bin/npm \
    /usr/local/bin/npx \
    /usr/local/bin/corepack \
    /usr/local/bin/yarn \
    /usr/local/bin/yarnpkg \
    /usr/local/bin/pnpm \
    /usr/local/bin/pnpx \
    /opt/yarn-v*
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
USER nextjs
EXPOSE 3000
ENV PORT=3000
# Next.js standalone binds to $HOSTNAME; Docker defaults it to the container id,
# which leaves the server unreachable on localhost (breaking the healthcheck).
# Bind to all interfaces so the in-container healthcheck and port publish both work.
ENV HOSTNAME=0.0.0.0
CMD ["node", "server.js"]
