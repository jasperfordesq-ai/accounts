# Private Server configuration names only. The setup helper writes the real
# configuration and secret files outside the repository. Never put secret values
# in this file or copy a generated private-server environment into the checkout.

# Immutable container references supplied by a reviewed release manifest.
ACCOUNTS_POSTGRES_IMAGE=docker.io/library/postgres@sha256:<64-hex-digest>
ACCOUNTS_API_IMAGE=ghcr.io/owner/accounts-api@sha256:<64-hex-digest>
ACCOUNTS_FRONTEND_IMAGE=ghcr.io/owner/accounts-frontend@sha256:<64-hex-digest>

# Stable installation identity and exact browser origins.
PRIVATE_INSTALLATION_ID=<generated-guid>
PRIVATE_FRONTEND_PORT=3500
PRIVATE_SERVER_ORIGIN=https://device.tailnet-name.ts.net
PRIVATE_LOCAL_ORIGIN=http://localhost:3500
PRIVATE_ALLOWED_HOSTS=device.tailnet-name.ts.net;localhost;127.0.0.1

# One workspace and its first Owner are created only by --private-initialize.
PRIVATE_TENANT_NAME=<organisation-name>
PRIVATE_TENANT_SLUG=<organisation-slug>
PRIVATE_OWNER_EMAIL=<owner-email>
PRIVATE_OWNER_DISPLAY_NAME=<owner-display-name>

# Non-secret identifiers for the active cryptographic key records.
AUDIT_INTEGRITY_ACTIVE_KEY_ID=<generated-audit-key-id>
MFA_ENCRYPTION_ACTIVE_KEY_ID=<generated-mfa-key-id>

# Paths to setup-generated secret files. Use absolute paths. The example paths
# are illustrative and are not read by the application until explicitly selected.
POSTGRES_PASSWORD_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/postgres_password
POSTGRES_APPLICATION_PASSWORD_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/postgres_application_password
ACCOUNTS_MIGRATION_CONNECTION_STRING_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/accounts_migration_connection_string
ACCOUNTS_APPLICATION_CONNECTION_STRING_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/accounts_application_connection_string
AUTH_SESSION_SIGNING_KEY_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/auth_session_signing_key
AUDIT_INTEGRITY_SIGNING_KEY_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/audit_integrity_signing_key
DATABASE_TENANT_CONTEXT_KEY_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/database_tenant_context_key
IDENTITY_HMAC_KEY_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/identity_hmac_key
MFA_ENCRYPTION_KEY_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/mfa_encryption_key
ACCOUNTS_API_KEY_HASH_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/accounts_api_key_hash
ACCOUNTS_API_KEY_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/accounts_api_key
PRIVATE_INITIAL_OWNER_PASSWORD_FILE=C:/Users/<you>/AppData/Local/FilingBridge/server/secrets/private_initial_owner_password
